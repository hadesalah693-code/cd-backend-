# Postgres connection (Supabase or local) — used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/dentist370?schema=public"

# Server
PORT=3000
HOST=0.0.0.0

# App auth (dentist370 Cloud client) — short-lived access token
ACCESS_TOKEN_SECRET="change-me-access-secret"
ACCESS_TOKEN_TTL="15m"
# Refresh tokens are opaque + stored hashed; this only controls lifetime
REFRESH_TOKEN_TTL_DAYS=30

# The single link between dentist370 and dentistsbook (architecture doc section 6).
# Must be identical wherever both products verify the platform token.
LICENSE_SIGNING_SECRET="change-me-license-signing-secret"
PLATFORM_TOKEN_TTL="30d"

# Google OAuth Web Client ID (Google Cloud Console -> Credentials -> OAuth client ID).
# Must match the GOOGLE_CLIENT_ID constant in app/app.js. Leave empty to disable
# "Sign in with Google" — /v1/auth/google then returns 501 instead of crashing.
GOOGLE_CLIENT_ID=""
